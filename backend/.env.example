# Optional API keys. The sign-practice MVP can load with the committed demo DB
# and keypoint assets, but these keys are needed for the full service flows.
CULTURE_API_KEY=
CULTURE_API_KEY2=
KRDICT_API_KEY=
GOOGLE_VISION_API_KEY=
GROQ_API_KEY=
MIDM_BASE_URL=http://127.0.0.1:8000/v1
MIDM_MODEL=midm-mini
MIDM_API_KEY=
MIDM_MODEL_NAME=K-intelligence/Midm-2.0-Mini-Instruct
MIDM_SERVED_MODEL_NAME=midm-mini
MIDM_HOST=127.0.0.1
MIDM_PORT=8000
MIDM_TENSOR_PARALLEL_SIZE=1
MIDM_CUDA_VISIBLE_DEVICES=
VOICE_SERVICE_URL=http://127.0.0.1:4100
VOICE_STT_BACKEND=mock
VOICE_TTS_BACKEND=supertonic
VOICE_HOST=127.0.0.1
VOICE_PORT=4100
# Server STT default: use large-v3 for Korean demo quality; use turbo if latency dominates.
WHISPER_MODEL_SIZE=large-v3
WHISPER_MODEL_PATH=
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_CUDA_VISIBLE_DEVICES=
SUPERTONIC_REPO_DIR=
SUPERTONIC_ASSET_DIR=
SUPERTONIC_HOME_DIR=
SUPERTONIC_VOICE=F1
SUPERTONIC_TOTAL_STEPS=8
# Supertonic Python ONNX path currently uses CPU provider; keep this off unless tested.
SUPERTONIC_USE_GPU=0
# TTS default:
# Run Supertonic from its dedicated GUI/service environment, not from conda v1.
# Keep VOICE_TTS_BACKEND=supertonic and point VOICE_SERVICE_URL at that service.
# If you run backend/voice_service.py as the bridge, set VOICE_PYTHON_BIN to the
# separate Python executable that has the Supertonic runtime installed.

# Optional Python override.
# Windows example: PYTHON_BIN=python
# macOS/Linux example: PYTHON_BIN=python3
# Local v1 example: PYTHON_BIN=/opt/homebrew/Caskroom/miniforge/base/envs/v1/bin/python
PYTHON_BIN=
VOICE_PYTHON_BIN=
